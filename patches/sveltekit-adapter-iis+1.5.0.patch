+    // Fall back to copySync + removeSync which avoids the rename entirely.
+    try {
+      fs.moveSync(from, to)
+    } catch (err) {
+      if (err.code === 'EPERM' || err.code === 'EACCES') {
+        fs.copySync(from, to)
